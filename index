<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora de Autonomía - Project One SV</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; color: #333; padding: 20px; }
        .container { max-width: 800px; margin: 0 auto; background: white; padding: 30px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h1 { color: #2c3e50; text-align: center; border-bottom: 2px solid #3498db; padding-bottom: 10px; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
        .control-group { background: #f8f9fa; padding: 15px; border-radius: 8px; border: 1px solid #e9ecef; }
        label { font-weight: bold; display: block; margin-bottom: 8px; color: #495057; }
        input[type=range] { width: 100%; margin-bottom: 10px; }
        .value-display { font-size: 1.1em; color: #3498db; font-weight: bold; float: right; }
        .results { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; }
        .card { background: #2c3e50; color: white; padding: 20px; border-radius: 8px; text-align: center; }
        .card.highlight { background: #27ae60; }
        .card h3 { margin: 0 0 10px 0; font-size: 0.9em; text-transform: uppercase; letter-spacing: 1px; color: #bdc3c7; }
        .card p { margin: 0; font-size: 2em; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Simulador Híbrido de Patrullaje</h1>
        
        <div class="grid">
            <div class="control-group">
                <label>Ancho de Zona de Cultivo (m) <span id="val-zona" class="value-display">7.0</span></label>
                <input type="range" id="zona" min="5" max="10" step="0.5" value="7" oninput="calcular()">
                
                <label>Ancho de Visión del Robot (m) <span id="val-vision" class="value-display">1.5</span></label>
                <input type="range" id="vision" min="1.0" max="2.5" step="0.1" value="1.5" oninput="calcular()">
            </div>
            <div class="control-group">
                <label>Velocidad de Patrullaje (m/s) <span id="val-vel" class="value-display">1.2</span></label>
                <input type="range" id="vel" min="0.5" max="2.0" step="0.1" value="1.2" oninput="calcular()">
                
                <label>Capacidad Tanque Gasolina (Lts) <span id="val-tanque" class="value-display">2.0</span></label>
                <input type="range" id="tanque" min="1.0" max="5.0" step="0.5" value="2.0" oninput="calcular()">
            </div>
        </div>

        <div class="results">
            <div class="card">
                <h3>Pasillos Necesarios</h3>
                <p id="res-pasillos">190</p>
            </div>
            <div class="card">
                <h3>Tiempo por Invernadero</h3>
                <p><span id="res-tiempo">2.4</span> h</p>
            </div>
            <div class="card highlight">
                <h3>Invernaderos por Tanque</h3>
                <p id="res-autonomia">2.9</p>
            </div>
        </div>
    </div>

    <script>
        function calcular() {
            // Obtener valores
            const zona = parseFloat(document.getElementById('zona').value);
            const vision = parseFloat(document.getElementById('vision').value);
            const vel = parseFloat(document.getElementById('vel').value);
            const tanque = parseFloat(document.getElementById('tanque').value);

            // Actualizar etiquetas
            document.getElementById('val-zona').innerText = zona.toFixed(1);
            document.getElementById('val-vision').innerText = vision.toFixed(1);
            document.getElementById('val-vel').innerText = vel.toFixed(1);
            document.getElementById('val-tanque').innerText = tanque.toFixed(1);

            // Cálculos
            const pasillosPorZona = Math.ceil(zona / vision);
            const totalPasillos = 38 * pasillosPorZona; // 38 zonas fijas (19 por lado)
            const distanciaTotal = totalPasillos * 36; // 36m de largo
            
            const tiempoMovimientoMin = (distanciaTotal / vel) / 60;
            const tiempoGirosMin = (totalPasillos * 15) / 60; // 15 seg por giro
            const tiempoTotalHoras = (tiempoMovimientoMin + tiempoGirosMin) / 60;
            
            const autonomiaGeneradorHoras = tanque * 3.5; // 3.5 horas por litro a baja carga
            const invernaderosPorTanque = autonomiaGeneradorHoras / tiempoTotalHoras;

            // Mostrar resultados
            document.getElementById('res-pasillos').innerText = totalPasillos;
            document.getElementById('res-tiempo').innerText = tiempoTotalHoras.toFixed(1);
            document.getElementById('res-autonomia').innerText = invernaderosPorTanque.toFixed(1);
        }
        calcular(); // Calcular al cargar
    </script>
</body>
</html>
